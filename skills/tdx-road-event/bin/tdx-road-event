#!/usr/bin/env python3
"""tdx-road-event CLI wrapper for OpenClaw exec.

Usage:
    tdx-road-event road_event_live_city --city 台南
    tdx-road-event road_event_city_history --city 高雄
    tdx-road-event road_event_freeway
    tdx-road-event road_event_highway
"""
from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path

SKILL_BIN = Path(__file__).resolve().parent
SKILL_DIR = SKILL_BIN.parent
SHARED_CORE_DIR = SKILL_DIR.parent / "tdx-shared-core"

sys.path.insert(0, str(SKILL_DIR))
sys.path.insert(0, str(SHARED_CORE_DIR))

from road_event_query import execute  # noqa: E402


def main() -> None:
    parser = argparse.ArgumentParser(description="TDX 道路事件查詢")
    parser.add_argument(
        "sub_command",
        choices=["road_event_live_city", "road_event_city_history", "road_event_freeway", "road_event_highway"],
        help="查詢類型",
    )
    parser.add_argument("--city", help="城市名稱（road_event_live_city / road_event_city_history 必填）")
    parser.add_argument("--keyword", help="事件關鍵字過濾")
    parser.add_argument("--top", type=int, default=3, help="回傳筆數上限（預設 3）")
    args = parser.parse_args()

    # 城市事件 intent 必須透過 tdx-city-road-query wrapper，禁止直接呼叫
    # TDX_WRAPPER=1 表示由 wrapper 內部呼叫，豁免 redirect guard
    _CITY_INTENTS = {"road_event_live_city", "road_event_city_history"}
    if args.sub_command in _CITY_INTENTS and not os.environ.get("TDX_WRAPPER"):
        print(json.dumps({
            "status": "redirect",
            "use_instead": "python3 /home/amakumo/.openclaw/workspace-nagi/skills/tdx-road-event/bin/tdx-city-road-query --city <城市>",
            "reason": "城市路況查詢必須透過 tdx-city-road-query wrapper（避免並行 429）",
        }, ensure_ascii=False, indent=2))
        sys.exit(3)  # exit 3 = redirect，改用 wrapper

    params = {
        "intent": args.sub_command,
        "top": args.top,
    }
    if args.city:
        params["city"] = args.city
    if args.keyword:
        params["keyword"] = args.keyword

    try:
        result = execute(params)
        print(json.dumps(result, ensure_ascii=False, indent=2))
        if result.get("status") in ("upstream_error", "rate_limited", "auth_error"):
            sys.exit(2)  # exit 2 = 上游錯誤，禁止重試
        elif result.get("status") not in ("ok", "mapped_only", "not_prechecked", "needs_clarification", "no_data"):
            sys.exit(1)
    except Exception as exc:
        error_output = {
            "status": "error",
            "intent": args.sub_command,
            "summary": str(exc),
            "items": [],
        }
        print(json.dumps(error_output, ensure_ascii=False, indent=2), file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
