#!/usr/bin/env python3
"""tdx-road-live CLI wrapper for OpenClaw exec.

Usage:
    tdx-road-live traffic_live_summary --city 高雄
    tdx-road-live congestion_level --city 台北
    tdx-road-live traffic_news --city 台南
    tdx-road-live cctv_info --city 高雄
"""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

SKILL_BIN = Path(__file__).resolve().parent
SKILL_DIR = SKILL_BIN.parent
SHARED_CORE_DIR = SKILL_DIR.parent / "tdx-shared-core"

sys.path.insert(0, str(SKILL_DIR))
sys.path.insert(0, str(SHARED_CORE_DIR))

from road_live_query import execute  # noqa: E402


def main() -> None:
    parser = argparse.ArgumentParser(description="TDX 路況資訊查詢")
    parser.add_argument(
        "sub_command",
        choices=["traffic_live_summary", "congestion_level", "traffic_news", "cctv_info"],
        help="查詢類型",
    )
    parser.add_argument("--city", required=True, help="城市名稱（如 高雄、台北、台南）")
    parser.add_argument("--keyword", help="路段關鍵字過濾")
    parser.add_argument("--top", type=int, default=3, help="回傳筆數上限（預設 3）")
    args = parser.parse_args()

    params = {
        "intent": args.sub_command,
        "city": args.city,
        "top": args.top,
    }
    if args.keyword:
        params["keyword"] = args.keyword

    try:
        result = execute(params)
        print(json.dumps(result, ensure_ascii=False, indent=2))
        if result.get("status") in ("upstream_error", "rate_limited", "auth_error"):
            sys.exit(2)  # exit 2 = 上游錯誤，禁止重試
        elif result.get("status") not in ("ok", "mapped_only", "not_prechecked", "needs_clarification", "no_data"):
            sys.exit(1)
    except Exception as exc:
        error_output = {
            "status": "error",
            "intent": args.sub_command,
            "summary": str(exc),
            "items": [],
        }
        print(json.dumps(error_output, ensure_ascii=False, indent=2), file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
